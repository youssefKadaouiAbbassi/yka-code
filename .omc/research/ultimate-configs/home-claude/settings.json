{
  "$schema": "https://claude.ai/schemas/settings.json",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOG_LEVEL": "warn"
  },

  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git remote -v:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo view:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(date)",
      "Bash(env:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(python3 --version)",
      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(go version)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(jq:*)",
      "Bash(curl -s:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo rm -rf:*)",
      "Bash(chmod -R 777:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(mkfs:*)",
      "Bash(dd if=/dev/zero:*)",
      "Bash(dd if=/dev/random:*)",
      "Bash(> /dev/sda:*)",
      "Bash(curl:*|bash)",
      "Bash(curl:*| bash)",
      "Bash(wget:*|bash)",
      "Bash(wget:*| bash)",
      "Bash(eval:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform apply -auto-approve:*)",
      "Bash(pulumi destroy:*)",
      "Bash(kubectl delete namespace:*)",
      "Bash(kubectl delete ns:*)",
      "Bash(docker system prune -af:*)",
      "Bash(docker rm -f $(docker ps -aq):*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(DROP TABLE:*)",
      "Bash(TRUNCATE:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(init 0:*)",
      "Bash(systemctl stop:*)",
      "Bash(kill -9 -1:*)",
      "Bash(killall:*)",
      "Bash(pkill -9:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(pip upload:*)",
      "Bash(twine upload:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/id_*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-destructive-blocker.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-secrets-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-lint-gate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/stop-summary.sh"
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "echo \"$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'no-git') | $(date +%H:%M) | cost: $CLAUDE_CODE_SESSION_COST\""
  },

  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": false,
  "teammateMode": "tmux"
}
